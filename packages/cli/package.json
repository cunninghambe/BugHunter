{
  "name": "bughunter",
  "version": "0.1.0",
  "description": "Exhaustive mutation-based UI + API bug hunter for local dev apps",
  "type": "module",
  "bin": {
    "bughunter": "./dist/cli/main.js"
  },
  "files": ["dist/**", "viewer-dist/**"],
  "scripts": {
    "build": "../../node_modules/.bin/tsc -p tsconfig.json && mkdir -p dist/perf/web-vitals-vendored && cp src/perf/web-vitals-vendored/web-vitals.umd.js dist/perf/web-vitals-vendored/ && node build.mjs",
    "typecheck": "../../node_modules/.bin/tsc -p tsconfig.json --noEmit",
    "test": "../../node_modules/.bin/vitest run",
    "test:watch": "../../node_modules/.bin/vitest",
    "test:e2e": "../../node_modules/.bin/vitest run --config vitest.e2e.config.ts",
    "test:xss-fixture": "../../node_modules/.bin/vitest run src/phases/execute-xss.test.ts",
    "dev": "../../node_modules/.bin/tsx watch src/cli/main.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "open": "10.1.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@paralleldrive/cuid2": "2.2.2",
    "fast-check": "3.23.2",
    "glob": "11.0.2",
    "ink": "^4.4.1",
    "micromatch": "4.0.8",
    "picocolors": "1.1.1",
    "playwright-core": "1.52.0",
    "react": "^18.3.1",
    "zod": "3.25.76",
    "better-sqlite3": "11.3.0"
  },
  "devDependencies": {
    "@types/micromatch": "4.0.9",
    "@types/node": "22.19.17",
    "@types/react": "^18.3.28",
    "ink-testing-library": "^3.0.0",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "4.1.5",
    "@types/better-sqlite3": "7.6.11"
  },
  "engines": {
    "node": ">=20"
  }
}
